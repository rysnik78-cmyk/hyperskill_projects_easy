import argparse
import math

# function here
def calculate_principal(n, a, i):
    p = a / ((i * (1 + i)**n)/((1+i)**n-1))
    overpayment = math.ceil(a * n - p)
    return f'Your loan principal = {int(p)}!\nOverpayment = {overpayment}'

def calculate_periods(p, a, i):
    n = math.ceil(math.log(a/(a - i * p), 1 + i))
    overpayment = math.ceil(a * n - p)
    if n % 12 == 0:
        months = f''
    elif n % 12 == 1:
        months = 'and 1 month '
    else:
        months = f'and {n % 12} months '
    if n // 12 == 0:
        years = ""
    elif n // 12 == 1:
        years = '1 year'
    else:
        years = f'{n // 12} years'

    return f'It will take {years} {months}to repay this loan!\nOverpayment = {overpayment}'


def calculate_payment(t, p, n, i):
    list_of_payments = []
    if t == 'annuity':
        a = math.ceil(p * i * (1 + i)**n /((1+i)**n-1))
        overpayment = math.ceil(a * n - p)
        return f'Your annuity payment = {a}!\nOverpayment = {overpayment}'
    else: # diff
        list_of_payments_string = []
        sum_of_d = 0
        for m in range(1, n + 1):
            d = math.ceil(p / n + i * (p - p * (m -1) / n))
            sum_of_d += d
            list_of_payments += f'Month {m}: payment is {d}\n'
            list_of_payments_string = "".join(list_of_payments)

        overpayment = math.ceil(sum_of_d - p)
        return f'{list_of_payments_string}\nOverpayment = {overpayment}'




